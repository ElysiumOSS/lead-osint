# Lead-OSINT environment configuration
# Copy to `.env` and fill in. `.env` is git-ignored — never commit real secrets.
#
# Only ONE key is truly required (Gemini), and only for the AI features
# (ocr, assess, outreach draft). Everything else is optional and degrades
# gracefully: ingest, embed, rank, search, view, and export work with no keys.

# --- Gemini (required for `ocr`, `assess`, `outreach draft`) ----------------
# Vision OCR of business cards / badges / screenshots, AI relevance assessment,
# and outreach drafting. Get a key: https://aistudio.google.com/apikey
#
# Set EXACTLY ONE of the two below. GOOGLE_API_KEY is accepted as an alias, but
# if BOTH are set the @google/genai SDK prints a "both keys set" warning and
# prefers GOOGLE_API_KEY — so pick one and leave the other unset/commented.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional model overrides (sensible defaults are used if unset).
GEMINI_OCR_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Enrichment / OSINT (all optional) -------------------------------------
# Used by `enrich` and by `assess --web` to research a lead from public sources.
# Each enricher fails soft when its key is absent.

# GitHub: raises the public API rate limit and improves person lookups for
# `assess --web` / `enrich --github`. A classic token with NO scopes (public
# read) is enough. https://github.com/settings/tokens  (GH_TOKEN also accepted)
GITHUB_TOKEN=

# Exa: enables web search to summarize a lead into sourced notes
# (`enrich --exa` and the Exa half of `assess --web`). https://exa.ai
EXA_API_KEY=

# Company registry: `enrich --orgs` uses Wikidata (free, keyless, global) to add
# a short company description — no token needed, nothing to configure here.

# SEC EDGAR: full-text company search for `enrich --orgs`. The SEC requires a
# descriptive User-Agent that includes a contact email, e.g.
# "Your Name your@email.com". No signup needed.
SEC_USER_AGENT=

# --- SMTP (required only for `outreach send`) -------------------------------
# Drafts are generated and stored without these; sending is gated and opt-in.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
OUTREACH_FROM_NAME=
OUTREACH_FROM_EMAIL=

# --- Storage ----------------------------------------------------------------
# Path to the embedded SQLite database (created on first run).
LEAD_OSINT_DB=data/leads.db

# --- Privacy ----------------------------------------------------------------
# Set to 1 to block any command that would send a lead's data to a third party
# (ocr, enrich, assess, outreach). Override per-run with --allow-external.
# Ingest, embed, rank, search, view, export, and `forget` always stay local.
# LEAD_OSINT_LOCAL_ONLY=1
