{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"lib": ["ES2022", "DOM"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node", "bun"]
	},
	"exclude": ["src/**/*.test.ts", "node_modules", "lib", "data"],
	"include": ["src"]
}
