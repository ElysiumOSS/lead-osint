{
	"name": "lead-osint",
	"version": "0.1.0",
	"description": "Lead-OSINT pipeline: ingest contacts from event scrapers and image OCR, normalize into an embedded SQLite + sqlite-vec store, rank leads by startup pitch-fit with local embeddings, explore relationships in a self-contained interactive HTML graph, and draft outreach.",
	"keywords": [
		"osint",
		"crm",
		"leads",
		"networking",
		"sqlite-vec",
		"embeddings",
		"ocr",
		"gemini",
		"vector-search",
		"cli"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ElysiumOSS/lead-osint.git"
	},
	"license": "MIT",
	"author": {
		"name": "Mike Odnis",
		"url": "https://github.com/WomB0ComB0"
	},
	"type": "module",
	"main": "lib/index.js",
	"bin": {
		"lead-osint": "lib/cli.js"
	},
	"files": [
		"LICENSE.md",
		"README.md",
		"lib/",
		"package.json"
	],
	"scripts": {
		"build": "tsdown",
		"start": "bun run src/cli.ts",
		"docs": "bunx typedoc --entryPointStrategy Expand src",
		"format": "biome format --write src",
		"lint": "biome check src",
		"lint:knip": "knip",
		"lint:md": "markdownlint \"**/*.md\" \".github/**/*.md\" --rules sentences-per-line",
		"lint:packages": "bun pm ls",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"tsc": "tsc"
	},
	"dependencies": {
		"@google/genai": "^1.30.0",
		"@xenova/transformers": "^2.17.2",
		"dotenv": "^17.2.3",
		"effect": "^3.19.15",
		"nodemailer": "^7.0.9",
		"sqlite-vec": "^0.1.7-alpha.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@release-it/conventional-changelog": "10.0.1",
		"@types/bun": "^1.3.10",
		"@types/node": "24.6.2",
		"@types/nodemailer": "^7.0.4",
		"@vitest/coverage-v8": "3.2.4",
		"console-fail-test": "0.5.0",
		"cspell": "9.2.1",
		"knip": "5.64.1",
		"markdownlint": "0.38.0",
		"markdownlint-cli": "0.45.0",
		"release-it": "19.0.5",
		"sentences-per-line": "0.3.0",
		"tsdown": "0.15.6",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"publishConfig": {
		"provenance": true
	}
}
